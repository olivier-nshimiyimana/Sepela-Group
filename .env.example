# =============================================================================
# Local development (.env.local)
# =============================================================================

# Neon PostgreSQL — use the POOLED connection string from your Neon dashboard
# Hostname must include "-pooler" (e.g. ep-xxx-pooler.us-east-1.aws.neon.tech)
# Use sslmode=require only — channel_binding is for psql/libpq, not this Next.js app
# Example:
# DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Optional: direct/unpooled connection for local migrations only
# DATABASE_URL_UNPOOLED=

# Optional: DB timeouts in ms (app default 10000, CLI migrate/seed default 30000)
# DB_TIMEOUT_MS=10000
# DB_CLI_TIMEOUT_MS=30000

# Admin credentials for the CMS (/admin)
# Production: use a strong password and a random secret (32+ characters)
ADMIN_PASSWORD=sepela-admin
ADMIN_SESSION_SECRET=change-this-to-a-long-random-string

# =============================================================================
# Render.com (free-tier test deploy)
# =============================================================================
# 1. Push repo to GitHub, then deploy via render.yaml (Blueprint) or manual Web Service
# 2. In Render → Settings, set:
#      Build Command:  npm ci && npm run build:render
#      Start Command:  npm start
#      Node version:   20  (or add NODE_VERSION=20 in Environment)
#    Environment variables:
#      DATABASE_URL          = Neon pooled URL (required)
#      ADMIN_PASSWORD        = strong password (required in production)
#      ADMIN_SESSION_SECRET  = 32+ random chars (required in production)
#      NODE_ENV              = production (set automatically by Render)
# 3. Build runs: npm ci && npm run build:render  (migrates DB, then next build)
# 4. Start runs:  npm start  (binds to Render PORT)
# 5. First-time data: run locally against production DB:
#      set DATABASE_URL=postgresql://...
#      npm run db:seed:prod
# 6. Site URL: https://sepela-group.onrender.com  (or your assigned *.onrender.com host)
# 7. Admin: https://your-app.onrender.com/admin/login
#
# Free-tier notes:
# - Service sleeps after ~15 min idle; first request may take 30–60s (cold start)
# - Disk is ephemeral: admin image uploads are lost on redeploy — use committed /public assets for test
# - Use Neon for all persistent data (products, news, settings, contact form)
